---
interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
  cta?: { text: string; href: string };
  gradient?: boolean;
  image?: string;
  overlay?: 'dark' | 'green';
  tall?: boolean;
}

const { title, subtitle, tagline, cta, gradient = false, image, overlay = 'dark', tall = false } = Astro.props;
---

<section
  class:list={[
    'relative px-4 text-center overflow-hidden',
    tall ? 'py-32 md:py-44' : 'py-20 md:py-28',
    !image && gradient
      ? 'bg-gradient-to-br from-verde-padure to-verde-pasune'
      : !image ? 'bg-verde-padure' : '',
  ]}
>
  {image && (
    <div class="absolute inset-0">
      <img
        src={image}
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div
        class:list={[
          'absolute inset-0',
          overlay === 'green'
            ? 'bg-gradient-to-b from-verde-padure/70 via-verde-padure/50 to-verde-padure/80'
            : 'bg-gradient-to-b from-black/60 via-black/40 to-black/70',
        ]}
      />
    </div>
  )}

  <div class="relative z-10 max-w-4xl mx-auto">
    {tagline && (
      <p class="text-sm text-white/70 mb-4 tracking-[0.2em] uppercase font-medium">{tagline}</p>
    )}

    <h1 class="font-heading text-4xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight mb-6 drop-shadow-lg">
      {title}
    </h1>

    {subtitle && (
      <p class="text-xl md:text-2xl text-white/90 font-heading mb-8 drop-shadow-md">
        {subtitle}
      </p>
    )}

    {cta && (
      <a
        href={cta.href}
        class="inline-block bg-teracota hover:bg-teracota/90 text-white px-8 py-3.5 rounded-lg font-medium text-lg transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        {cta.text}
      </a>
    )}
  </div>
</section>
