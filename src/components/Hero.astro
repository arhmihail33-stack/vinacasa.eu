---
interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
  cta?: { text: string; href: string };
  gradient?: boolean;
  backgroundImage?: string;
}

const { title, subtitle, tagline, cta, gradient = false, backgroundImage } = Astro.props;
---

<section
  class:list={[
    'relative py-24 md:py-36 px-4 text-center overflow-hidden',
    !backgroundImage && (gradient
      ? 'bg-gradient-to-br from-verde-padure to-verde-pasune'
      : 'bg-verde-padure'),
  ]}
>
  {backgroundImage && (
    <img
      src={backgroundImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
  )}
  {backgroundImage && (
    <div class="absolute inset-0 bg-verde-padure/60"></div>
  )}

  <div class="relative z-10 max-w-4xl mx-auto">
    {tagline && (
      <p class="text-sm text-alb-var/70 mb-4 tracking-wide uppercase">{tagline}</p>
    )}

    <h1 class="font-heading text-5xl md:text-7xl font-bold text-white tracking-tight mb-6 drop-shadow-lg">
      {title}
    </h1>

    {subtitle && (
      <p class="text-xl md:text-2xl text-alb-var/90 font-heading mb-8 drop-shadow-md">
        {subtitle}
      </p>
    )}

    {cta && (
      <a
        href={cta.href}
        class="inline-block bg-teracota hover:bg-teracota/90 text-white px-8 py-3 rounded-lg font-medium text-lg transition-colors duration-200 shadow-lg"
      >
        {cta.text}
      </a>
    )}
  </div>
</section>
