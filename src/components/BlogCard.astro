---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  author?: string;
  image?: string;
}

const { title, description, date, slug, author, image } = Astro.props;

const formattedDate = date.toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const defaultImages = [
  'https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=600&h=400&fit=crop',
  'https://images.unsplash.com/photo-1464226184884-fa280b87c399?w=600&h=400&fit=crop',
  'https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600&h=400&fit=crop',
];
const imgSrc = image || defaultImages[slug.length % defaultImages.length];
---

<a href={`/blog/${slug}`} class="block group">
  <article class="bg-crem rounded-xl overflow-hidden shadow-sm border border-teracota-light/30 hover:shadow-lg transition-all duration-300">
    <div class="h-48 overflow-hidden">
      <img
        src={imgSrc}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </div>

    <div class="p-5">
      <h3 class="font-heading text-lg font-semibold text-verde-padure group-hover:text-teracota transition-colors duration-200 mb-1">
        {title}
      </h3>

      <div class="flex items-center gap-2 mb-2">
        <time class="text-xs text-lemn-stejar/60">{formattedDate}</time>
        {author && (
          <span class="text-xs text-lemn-stejar/60">&middot; {author}</span>
        )}
      </div>

      <p class="text-sm text-lemn-stejar line-clamp-2 mb-3">{description}</p>

      <span class="text-teracota text-sm font-medium group-hover:translate-x-1 inline-block transition-transform duration-200">
        Citește mai mult &rarr;
      </span>
    </div>
  </article>
</a>
