---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  author?: string;
}

const { title, description, date, slug, author } = Astro.props;

const formattedDate = date.toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="block group">
  <article class="bg-crem rounded-lg overflow-hidden shadow-sm border border-teracota-light/30 hover:shadow-md transition-shadow duration-200">
    <!-- Image -->
    <div class="h-40 overflow-hidden">
      <img
        src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=600&h=300&fit=crop&q=80"
        alt={title}
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    </div>

    <!-- Body -->
    <div class="p-5">
      <h3 class="font-heading text-lg font-semibold text-verde-padure group-hover:text-teracota transition-colors duration-200 mb-1">
        {title}
      </h3>

      <div class="flex items-center gap-2 mb-2">
        <time class="text-xs text-lemn-stejar/60">{formattedDate}</time>
        {author && (
          <span class="text-xs text-lemn-stejar/60">&middot; {author}</span>
        )}
      </div>

      <p class="text-sm text-lemn-stejar line-clamp-2 mb-3">{description}</p>

      <span class="text-teracota text-sm font-medium">
        Citește mai mult &rarr;
      </span>
    </div>
  </article>
</a>
