---
interface Props {
  title: string;
  icon?: string;
  variant?: 'default' | 'accent';
  image?: string;
}

const { title, icon, variant = 'default', image } = Astro.props;
---

<div
  class:list={[
    'rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300',
    variant === 'accent'
      ? 'bg-teracota-light/30 border border-teracota/20'
      : 'bg-crem border border-teracota-light/50',
  ]}
  data-hover-lift
>
  {image && (
    <div class="h-48 overflow-hidden">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-6">
    {icon && !image && <div class="text-3xl mb-3">{icon}</div>}
    <h3 class="font-heading font-semibold text-lg text-verde-padure mb-2">{title}</h3>
    <div class="text-sm text-lemn-stejar leading-relaxed">
      <slot />
    </div>
  </div>
</div>
