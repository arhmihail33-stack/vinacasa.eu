---
interface Props {
  title: string;
  icon?: string;
  variant?: 'default' | 'accent';
}

const { title, icon, variant = 'default' } = Astro.props;
---

<div
  class:list={[
    'rounded-lg p-6 shadow-sm',
    variant === 'accent'
      ? 'bg-teracota-light/30 border border-teracota/20'
      : 'bg-crem border border-teracota-light/50',
  ]}
>
  {icon && <div class="text-2xl mb-3">{icon}</div>}
  <h3 class="font-heading font-semibold text-lg text-verde-padure mb-2">{title}</h3>
  <div class="text-sm text-lemn-stejar">
    <slot />
  </div>
</div>
