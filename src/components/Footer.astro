---
const quickLinks = [
  { href: '/', label: 'Acasă' },
  { href: '/ferma', label: 'Fermă' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="bg-verde-padure text-white/90 py-16 px-4">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Col 1: About -->
    <div>
      <h3 class="font-heading font-bold text-xl text-white mb-3">RAIDAVA</h3>
      <p class="text-sm text-white/70 leading-relaxed">
        Micro-fermă regenerativă în Vulturești, Argeș
      </p>
    </div>

    <!-- Col 2: Navigation -->
    <div>
      <h3 class="font-heading font-bold text-lg text-white mb-3">Navigare</h3>
      <ul class="space-y-2">
        {quickLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm text-white/70 hover:text-white transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Col 3: Contact -->
    <div>
      <h3 class="font-heading font-bold text-lg text-white mb-3">Contact</h3>
      <ul class="space-y-2 text-sm text-white/70">
        <li>
          <a href="mailto:contact@vinacasa.eu" class="hover:text-white transition-colors duration-200">
            contact@vinacasa.eu
          </a>
        </li>
        <li>Vulturești, Argeș, România</li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="max-w-7xl mx-auto mt-10 pt-6 border-t border-white/20 text-center text-xs text-white/50">
    &copy; {new Date().getFullYear()} RAIDAVA. Toate drepturile rezervate.
  </div>
</footer>
