---
interface Props {
  items: Array<{ period: string; description: string; highlight?: boolean }>;
}

const { items } = Astro.props;
---

<div class="relative py-8 px-4">
  <!-- Vertical line -->
  <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-verde-pasune/30 -translate-x-1/2"></div>

  <div class="space-y-10">
    {items.map((item, index) => (
      <div class="relative grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8">
        {/* Dot */}
        <div
          class:list={[
            'absolute left-4 md:left-1/2 w-4 h-4 rounded-full -translate-x-1/2 top-1 z-10 border-2 border-white',
            item.highlight ? 'bg-teracota' : 'bg-verde-pasune',
          ]}
        />

        {/* Content — alternating sides on desktop */}
        {index % 2 === 0 ? (
          <>
            <div class="pl-10 md:pl-0 md:pr-12 md:text-right">
              <p class="font-heading font-bold text-lemn-nuc">{item.period}</p>
              <p class="text-sm text-lemn-stejar mt-1">{item.description}</p>
            </div>
            <div class="hidden md:block" />
          </>
        ) : (
          <>
            <div class="hidden md:block" />
            <div class="pl-10 md:pl-12">
              <p class="font-heading font-bold text-lemn-nuc">{item.period}</p>
              <p class="text-sm text-lemn-stejar mt-1">{item.description}</p>
            </div>
          </>
        )}
      </div>
    ))}
  </div>
</div>
