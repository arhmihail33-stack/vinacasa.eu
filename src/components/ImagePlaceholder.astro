---
interface Props {
  alt: string;
  aspect?: 'landscape' | 'square' | 'portrait' | 'hero';
  variant?: 'green' | 'earth' | 'warm' | 'tech';
  icon?: string;
  className?: string;
}

const { alt, aspect = 'landscape', variant = 'green', icon, className = '' } = Astro.props;

const aspectClasses = {
  landscape: 'aspect-video',
  square: 'aspect-square',
  portrait: 'aspect-[3/4]',
  hero: 'h-[400px] md:h-[500px]',
};

const gradientClasses = {
  green: 'from-verde-padure/30 via-verde-pasune/20 to-alb-var',
  earth: 'from-lemn-stejar/20 via-teracota-light to-crem',
  warm: 'from-teracota/20 via-teracota-light to-alb-var',
  tech: 'from-verde-padure/40 via-lemn-nuc/20 to-verde-pasune/30',
};
---

<div
  class:list={[
    'relative overflow-hidden rounded-lg bg-gradient-to-br',
    gradientClasses[variant],
    aspectClasses[aspect],
    className,
  ]}
  role="img"
  aria-label={alt}
>
  <!-- Decorative SVG pattern overlay -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.07]" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id={`pat-${variant}`} width="40" height="40" patternUnits="userSpaceOnUse">
        <circle cx="20" cy="20" r="1.5" fill="currentColor" />
        <path d="M0 20h40M20 0v40" stroke="currentColor" stroke-width="0.3" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill={`url(#pat-${variant})`} />
  </svg>

  <!-- Content -->
  <div class="absolute inset-0 flex flex-col items-center justify-center p-4 text-center">
    {icon && <span class="text-4xl mb-2 opacity-60">{icon}</span>}
    <p class="text-sm italic text-lemn-stejar/50 max-w-[200px]">{alt}</p>
  </div>
</div>
