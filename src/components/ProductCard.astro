---
interface Props {
  title: string;
  category: string;
  season: string;
  available: boolean;
  description?: string;
  image?: string;
}

const { title, category, season, available, image } = Astro.props;

const productImages: Record<string, string> = {
  'Brânză de Capră': 'https://images.unsplash.com/photo-1486297678162-eb2a19b0a32d?w=600&h=400&fit=crop',
  'Ouă de Țară': 'https://images.unsplash.com/photo-1569288052389-dac9b0ac9eac?w=600&h=400&fit=crop',
};

const imgSrc = image || productImages[title] || 'https://images.unsplash.com/photo-1488459716781-31db52582fe9?w=600&h=400&fit=crop';
---

<article class="bg-crem rounded-xl overflow-hidden shadow-sm border border-teracota-light/30 hover:shadow-md transition-all duration-300 relative group" data-hover-lift>
  <div class="relative h-48 overflow-hidden">
    <img
      src={imgSrc}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent" />

    {available ? (
      <span class="absolute top-3 right-3 bg-verde-pasune text-white text-xs px-3 py-1 rounded-full font-medium shadow-sm">
        Disponibil
      </span>
    ) : (
      <span class="absolute top-3 right-3 bg-teracota-light text-lemn-stejar text-xs px-3 py-1 rounded-full font-medium shadow-sm">
        În curând
      </span>
    )}
  </div>

  <div class="p-5">
    <h3 class="font-heading font-semibold text-verde-padure mb-2">{title}</h3>

    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs text-lemn-stejar/60">{category}</span>
      <span class="text-xs text-lemn-stejar/60">&middot;</span>
      <span class="text-xs text-lemn-stejar/60">{season}</span>
    </div>

    <div class="text-sm text-lemn-stejar">
      <slot />
    </div>
  </div>
</article>
