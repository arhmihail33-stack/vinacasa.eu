---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'RAIDAVA — Prima ferma Hub-and-Spoke + Mulberry-Dike din Romania. Agricultura regenerativa in Vulturesti, Arges.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-cream text-green-primary font-body min-h-screen flex flex-col">
    <nav class="bg-green-primary text-white sticky top-0 z-50 shadow-md">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="font-heading font-bold text-xl tracking-tight hover:text-cream-dark transition-colors">
          RAIDAVA
        </a>
        <button id="menu-toggle" class="md:hidden p-2" aria-label="Meniu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <ul id="nav-links" class="hidden md:flex gap-6 text-sm font-medium">
          <li><a href="/" class="hover:text-cream-dark transition-colors">Acasa</a></li>
          <li><a href="/despre" class="hover:text-cream-dark transition-colors">Despre</a></li>
          <li><a href="/cercetare/sol-apa" class="hover:text-cream-dark transition-colors">Sol & Apa</a></li>
          <li><a href="/razvanis" class="hover:text-cream-dark transition-colors">Razvanis AI</a></li>
          <li><a href="/blog" class="hover:text-cream-dark transition-colors">Blog</a></li>
        </ul>
      </div>
      <div id="mobile-menu" class="hidden md:hidden px-4 pb-4">
        <ul class="flex flex-col gap-3 text-sm font-medium">
          <li><a href="/" class="block py-1 hover:text-cream-dark">Acasa</a></li>
          <li><a href="/despre" class="block py-1 hover:text-cream-dark">Despre</a></li>
          <li><a href="/cercetare/sol-apa" class="block py-1 hover:text-cream-dark">Sol & Apa</a></li>
          <li><a href="/razvanis" class="block py-1 hover:text-cream-dark">Razvanis AI</a></li>
          <li><a href="/blog" class="block py-1 hover:text-cream-dark">Blog</a></li>
        </ul>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-green-primary text-white py-8 mt-12">
      <div class="max-w-6xl mx-auto px-4 text-center text-sm">
        <p class="font-heading font-semibold text-lg mb-2">RAIDAVA</p>
        <p class="text-cream-dark">Vulturesti, comuna Vulturesti, judetul Arges, Romania</p>
        <p class="text-cream-dark mt-1">Contact: <a href="mailto:contact@vinacasa.eu" class="underline hover:text-white">contact@vinacasa.eu</a></p>
        <p class="text-cream-dark/60 mt-4">&copy; {new Date().getFullYear()} RAIDAVA. Agricultura regenerativa.</p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
