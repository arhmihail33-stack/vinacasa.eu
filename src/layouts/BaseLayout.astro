---
import Animations from '../components/Animations.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "RAIDAVA — produse artizanale din inima naturii", ogImage = "/og-default.jpg" } = Astro.props;
const canonicalURL = Astro.url;
---

<!DOCTYPE html>
<html lang="ro">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;700;900&display=swap"
      rel="stylesheet"
    />

    <style>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="bg-alb-var text-lemn-nuc font-body min-h-screen">
    <slot />
    <Animations />
  </body>
</html>
