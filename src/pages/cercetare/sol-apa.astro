---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import Card from '../../components/Card.astro';
import SectionSeparator from '../../components/SectionSeparator.astro';
---

<PageLayout title="Sol și Apă — Cercetare RAIDAVA" description="Analiză detaliată a solului, geologiei și resurselor de apă din zona Vulturești, Argeș.">

  <!-- 1. Hero -->
  <Hero title="Sol și Apă" subtitle="Cercetare științifică pentru agricultură informată" />

  <!-- 2. Separator -->
  <SectionSeparator />

  <!-- 3. Cadrul Geologic -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Cadrul Geologic</h2>
      <div class="bg-crem rounded-lg p-8 border border-teracota-light/50">
        <div class="space-y-4 text-lemn-stejar leading-relaxed">
          <p>
            Zona Vulturești se află la <span class="font-semibold text-verde-padure">contactul dintre Piemontul Getic</span> (subunitatea Platforma Cândești) și <span class="font-semibold text-verde-padure">Câmpia Română</span>. Substratul este format din depozite aluviale recente — argile, nisipuri și pietriș — aduse de afluenții Argeșului.
          </p>
          <p>
            O poziție geologică privilegiată care oferă o diversitate remarcabilă de soluri și forme de relief pe o suprafață compactă.
          </p>
        </div>
        <div class="mt-6 p-4 bg-verde-padure/5 rounded-lg border border-verde-padure/10">
          <h3 class="font-heading font-semibold text-verde-padure mb-2">Pietrișurile Cândești</h3>
          <p class="text-sm text-lemn-stejar">
            Formațiune cu grosime până la <span class="font-semibold text-verde-padure">180 m</span>, reprezintă acviferul principal al zonei. Alimentează fântânile și izvoarele naturale — o resursă strategică pentru fermă.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Mozaicul Pedologic -->
  <section class="py-16 bg-teracota-light/30">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Tipurile de Sol</h2>
      <div class="overflow-x-auto">
        <table class="w-full bg-crem rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-verde-padure text-white">
              <th class="font-heading font-semibold text-left px-4 py-3 text-sm">Zona Relief</th>
              <th class="font-heading font-semibold text-left px-4 py-3 text-sm">Tip Sol</th>
              <th class="font-heading font-semibold text-left px-4 py-3 text-sm">Caracteristici</th>
              <th class="font-heading font-semibold text-left px-4 py-3 text-sm">Potrivire RAIDAVA</th>
            </tr>
          </thead>
          <tbody class="text-sm text-lemn-stejar">
            <tr class="border-b border-teracota-light/30">
              <td class="px-4 py-3 font-medium text-verde-padure">Lunca inundabilă</td>
              <td class="px-4 py-3">Aluviosoluri</td>
              <td class="px-4 py-3">Fertile, bine drenate, humus bogat</td>
              <td class="px-4 py-3">
                <span class="inline-block bg-verde-pasune/20 text-verde-padure px-2 py-0.5 rounded text-xs font-medium">Culturi furajere, topinambur, lucernă</span>
              </td>
            </tr>
            <tr class="border-b border-teracota-light/30 even:bg-teracota-light/20">
              <td class="px-4 py-3 font-medium text-verde-padure">Terasă joasă</td>
              <td class="px-4 py-3">Cernoziomuri</td>
              <td class="px-4 py-3">Humus 3-5%, pH neutru, retenție apă bună</td>
              <td class="px-4 py-3">
                <span class="inline-block bg-verde-pasune/20 text-verde-padure px-2 py-0.5 rounded text-xs font-medium">Pășune, legume, grădină</span>
              </td>
            </tr>
            <tr class="border-b border-teracota-light/30">
              <td class="px-4 py-3 font-medium text-verde-padure">Versanți</td>
              <td class="px-4 py-3">Luvosoluri</td>
              <td class="px-4 py-3">Argiloase, ușor acide, drenaj moderat</td>
              <td class="px-4 py-3">
                <span class="inline-block bg-teracota/20 text-teracota px-2 py-0.5 rounded text-xs font-medium">Livadă, pădure alimentară</span>
              </td>
            </tr>
            <tr class="even:bg-teracota-light/20">
              <td class="px-4 py-3 font-medium text-verde-padure">Interfluvii</td>
              <td class="px-4 py-3">Preluvosoluri</td>
              <td class="px-4 py-3">Moderate, tranziție, pH slab acid</td>
              <td class="px-4 py-3">
                <span class="inline-block bg-teracota/20 text-teracota px-2 py-0.5 rounded text-xs font-medium">Cereale, cover crops</span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- 5. Separator -->
  <SectionSeparator variant="verde" />

  <!-- 6. Resurse de Apa -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Resurse de Apă</h2>

      <div class="grid md:grid-cols-2 gap-8 mb-10">
        <Card title="Apă Subterană">
          <p class="mb-2">Pânza freatică la <span class="font-semibold text-verde-padure">2-8 m</span> adâncime în luncă. Nivelul variază sezonier, fiind mai aproape de suprafață primăvara.</p>
          <p class="mb-2"><span class="font-semibold text-verde-padure">Pietrișurile Cândești</span> — acvifer cu grosime 180 m, resursă strategică regională.</p>
          <p>Fântâni tradiționale funcționale, accesibile prin puțuri simple.</p>
        </Card>

        <Card title="Apă de Suprafață">
          <p class="mb-2">Râul Argeș la <span class="font-semibold text-verde-padure">~5 km</span> distanță.</p>
          <p class="mb-2">Pârauri locale sezoniere — potențial pentru micro-baraje.</p>
          <p>Posibilitate amenajare <span class="font-semibold text-verde-padure">iaz colectare apă pluvială</span> pentru irigație suplimentară și acvacultură.</p>
        </Card>
      </div>

      <!-- Precipitații -->
      <div class="bg-crem rounded-lg p-6 border border-teracota-light/50">
        <h3 class="font-heading font-semibold text-lg mb-4 text-center text-verde-padure">
          Precipitații Medii Lunare — 734 mm/an
        </h3>
        <div class="overflow-x-auto">
          <table class="w-full bg-crem rounded-lg text-sm text-center">
            <thead>
              <tr class="bg-verde-padure text-white">
                <th class="px-2 py-2 font-heading font-semibold">Ian</th>
                <th class="px-2 py-2 font-heading font-semibold">Feb</th>
                <th class="px-2 py-2 font-heading font-semibold">Mar</th>
                <th class="px-2 py-2 font-heading font-semibold">Apr</th>
                <th class="px-2 py-2 font-heading font-semibold">Mai</th>
                <th class="px-2 py-2 font-heading font-semibold">Iun</th>
                <th class="px-2 py-2 font-heading font-semibold">Iul</th>
                <th class="px-2 py-2 font-heading font-semibold">Aug</th>
                <th class="px-2 py-2 font-heading font-semibold">Sep</th>
                <th class="px-2 py-2 font-heading font-semibold">Oct</th>
                <th class="px-2 py-2 font-heading font-semibold">Noi</th>
                <th class="px-2 py-2 font-heading font-semibold">Dec</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="px-2 py-3 font-medium">35</td>
                <td class="px-2 py-3 font-medium">32</td>
                <td class="px-2 py-3 font-medium">40</td>
                <td class="px-2 py-3 font-medium">55</td>
                <td class="px-2 py-3 font-medium bg-verde-pasune/20 font-bold text-verde-padure">75</td>
                <td class="px-2 py-3 font-medium bg-verde-pasune/20 font-bold text-verde-padure">85</td>
                <td class="px-2 py-3 font-medium bg-verde-pasune/20 font-bold text-verde-padure">70</td>
                <td class="px-2 py-3 font-medium">55</td>
                <td class="px-2 py-3 font-medium">45</td>
                <td class="px-2 py-3 font-medium">45</td>
                <td class="px-2 py-3 font-medium">45</td>
                <td class="px-2 py-3 font-medium">40</td>
              </tr>
              <tr class="text-xs text-lemn-stejar/50">
                <td class="px-2 py-1" colspan="12">Valori în mm. Lunile cu precipitații peste 70 mm sunt evidențiate. Sursa: ANM 2000-2025.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Implicații RAIDAVA -->
  <section class="py-16 bg-teracota-light/30">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Ce înseamnă pentru fermă</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <Card title="Lunca Aluvială">
          Solul aluvial din luncă este ideal pentru topinambur și lucernă — culturi furajere principale. Fertilitatea naturală elimină nevoia de amendamente costisitoare.
        </Card>
        <Card title="Precipitații Suficiente">
          Precipitațiile de 734 mm/an acoperă necesarul fără irigație suplimentară pentru majoritatea culturilor planificate. Distribuția favorabilă în sezonul de creștere este un avantaj major.
        </Card>
        <Card title="Versanți pentru Livadă">
          Versanții cu luvosoluri sunt potriviți pentru livadă tradițională și pădure alimentară. Luvosolurile argiloase susțin bine pomii fructiferi și arbuștii.
        </Card>
      </div>
    </div>
  </section>

  <!-- 8. Surse -->
  <section class="py-8">
    <div class="max-w-4xl mx-auto px-4">
      <h3 class="font-heading font-semibold text-lg text-verde-padure mb-3">Surse și referințe</h3>
      <ul class="text-sm text-lemn-stejar/60 space-y-1 list-disc list-inside">
        <li>Harta geologică a României 1:200.000</li>
        <li>Institutul Național de Geologie</li>
        <li>OSPA Argeș — Oficiul de Studii Pedologice și Agrochimice</li>
        <li>Date meteorologice ANM 2000-2025</li>
      </ul>
    </div>
  </section>

</PageLayout>
