---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import Card from '../../components/Card.astro';
import SectionSeparator from '../../components/SectionSeparator.astro';
---

<PageLayout title="Sol si Apa — Cercetare RAIDAVA" description="Analiza detaliata a solului, geologiei si resurselor de apa din zona Vulturesti, Arges.">

  <!-- 1. Hero -->
  <Hero title="Sol si Apa" subtitle="Cercetare stiintifica pentru agricultura informata" />

  <!-- 2. Separator -->
  <SectionSeparator />

  <!-- 3. Cadrul Geologic -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Cadrul Geologic</h2>
      <div class="bg-crem rounded-lg p-8 border border-teracota-light/50">
        <div class="space-y-4 text-lemn-stejar leading-relaxed">
          <p>
            Zona Vulturesti se afla la <span class="font-semibold text-verde-padure">contactul dintre Piemontul Getic</span> (subunitatea Platforma Candesti) si <span class="font-semibold text-verde-padure">Campia Romana</span>. Substratul este format din depozite aluviale recente — argile, nisipuri si pietrish — aduse de afluentii Argesului.
          </p>
          <p>
            O pozitie geologica privilegiata care ofera o diversitate remarcabila de soluri si forme de relief pe o suprafata compacta.
          </p>
        </div>
        <div class="mt-6 p-4 bg-verde-padure/5 rounded-lg border border-verde-padure/10">
          <h3 class="font-heading font-semibold text-verde-padure mb-2">Pietrisurile Candesti</h3>
          <p class="text-sm text-lemn-stejar">
            Formatiune cu grosime pana la <span class="font-semibold text-verde-padure">180 m</span>, reprezinta acviferul principal al zonei. Alimenteaza fantanile si izvoarele naturale — o resursa strategica pentru ferma.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Mozaicul Pedologic -->
  <section class="py-16 bg-teracota-light/30">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Tipurile de Sol</h2>
      <div class="overflow-x-auto">
        <table class="w-full bg-crem rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-verde-padure text-white">
              <th class="font-heading font-semibold text-left px-4 py-3 text-sm">Zona Relief</th>
              <th class="font-heading font-semibold text-left px-4 py-3 text-sm">Tip Sol</th>
              <th class="font-heading font-semibold text-left px-4 py-3 text-sm">Caracteristici</th>
              <th class="font-heading font-semibold text-left px-4 py-3 text-sm">Potrivire RAIDAVA</th>
            </tr>
          </thead>
          <tbody class="text-sm text-lemn-stejar">
            <tr class="border-b border-teracota-light/30">
              <td class="px-4 py-3 font-medium text-verde-padure">Lunca inundabila</td>
              <td class="px-4 py-3">Aluviosoluri</td>
              <td class="px-4 py-3">Fertile, bine drenate, humus bogat</td>
              <td class="px-4 py-3">
                <span class="inline-block bg-verde-pasune/20 text-verde-padure px-2 py-0.5 rounded text-xs font-medium">Culturi furajere, topinambur, lucerna</span>
              </td>
            </tr>
            <tr class="border-b border-teracota-light/30 even:bg-teracota-light/20">
              <td class="px-4 py-3 font-medium text-verde-padure">Terasa joasa</td>
              <td class="px-4 py-3">Cernoziomuri</td>
              <td class="px-4 py-3">Humus 3-5%, pH neutru, retentie apa buna</td>
              <td class="px-4 py-3">
                <span class="inline-block bg-verde-pasune/20 text-verde-padure px-2 py-0.5 rounded text-xs font-medium">Pasune, legume, gradina</span>
              </td>
            </tr>
            <tr class="border-b border-teracota-light/30">
              <td class="px-4 py-3 font-medium text-verde-padure">Versanti</td>
              <td class="px-4 py-3">Luvosoluri</td>
              <td class="px-4 py-3">Argiloase, usor acide, drenaj moderat</td>
              <td class="px-4 py-3">
                <span class="inline-block bg-teracota/20 text-teracota px-2 py-0.5 rounded text-xs font-medium">Livada, padure alimentara</span>
              </td>
            </tr>
            <tr class="even:bg-teracota-light/20">
              <td class="px-4 py-3 font-medium text-verde-padure">Interfluvii</td>
              <td class="px-4 py-3">Preluvosoluri</td>
              <td class="px-4 py-3">Moderate, tranzitie, pH slab acid</td>
              <td class="px-4 py-3">
                <span class="inline-block bg-teracota/20 text-teracota px-2 py-0.5 rounded text-xs font-medium">Cereale, cover crops</span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- 5. Separator -->
  <SectionSeparator variant="verde" />

  <!-- 6. Resurse de Apa -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Resurse de Apa</h2>

      <div class="grid md:grid-cols-2 gap-8 mb-10">
        <Card title="Apa Subterana">
          <p class="mb-2">Panza freatica la <span class="font-semibold text-verde-padure">2-8 m</span> adancime in lunca. Nivelul variaza sezonier, fiind mai aproape de suprafata primavara.</p>
          <p class="mb-2"><span class="font-semibold text-verde-padure">Pietrisurile Candesti</span> — acvifer cu grosime 180 m, resursa strategica regionala.</p>
          <p>Fantani traditionale functionale, accesibile prin puturi simple.</p>
        </Card>

        <Card title="Apa de Suprafata">
          <p class="mb-2">Raul Arges la <span class="font-semibold text-verde-padure">~5 km</span> distanta.</p>
          <p class="mb-2">Parauri locale sezoniere — potential pentru micro-baraje.</p>
          <p>Posibilitate amenajare <span class="font-semibold text-verde-padure">iaz colectare apa pluviala</span> pentru irigatie suplimentara si acvacultura.</p>
        </Card>
      </div>

      <!-- Precipitatii -->
      <div class="bg-crem rounded-lg p-6 border border-teracota-light/50">
        <h3 class="font-heading font-semibold text-lg mb-4 text-center text-verde-padure">
          Precipitatii Medii Lunare — 734 mm/an
        </h3>
        <div class="overflow-x-auto">
          <table class="w-full bg-crem rounded-lg text-sm text-center">
            <thead>
              <tr class="bg-verde-padure text-white">
                <th class="px-2 py-2 font-heading font-semibold">Ian</th>
                <th class="px-2 py-2 font-heading font-semibold">Feb</th>
                <th class="px-2 py-2 font-heading font-semibold">Mar</th>
                <th class="px-2 py-2 font-heading font-semibold">Apr</th>
                <th class="px-2 py-2 font-heading font-semibold">Mai</th>
                <th class="px-2 py-2 font-heading font-semibold">Iun</th>
                <th class="px-2 py-2 font-heading font-semibold">Iul</th>
                <th class="px-2 py-2 font-heading font-semibold">Aug</th>
                <th class="px-2 py-2 font-heading font-semibold">Sep</th>
                <th class="px-2 py-2 font-heading font-semibold">Oct</th>
                <th class="px-2 py-2 font-heading font-semibold">Noi</th>
                <th class="px-2 py-2 font-heading font-semibold">Dec</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="px-2 py-3 font-medium">35</td>
                <td class="px-2 py-3 font-medium">32</td>
                <td class="px-2 py-3 font-medium">40</td>
                <td class="px-2 py-3 font-medium">55</td>
                <td class="px-2 py-3 font-medium bg-verde-pasune/20 font-bold text-verde-padure">75</td>
                <td class="px-2 py-3 font-medium bg-verde-pasune/20 font-bold text-verde-padure">85</td>
                <td class="px-2 py-3 font-medium bg-verde-pasune/20 font-bold text-verde-padure">70</td>
                <td class="px-2 py-3 font-medium">55</td>
                <td class="px-2 py-3 font-medium">45</td>
                <td class="px-2 py-3 font-medium">45</td>
                <td class="px-2 py-3 font-medium">45</td>
                <td class="px-2 py-3 font-medium">40</td>
              </tr>
              <tr class="text-xs text-lemn-stejar/50">
                <td class="px-2 py-1" colspan="12">Valori in mm. Lunile cu precipitatii peste 70 mm sunt evidentiate. Sursa: ANM 2000-2025.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Implicatii RAIDAVA -->
  <section class="py-16 bg-teracota-light/30">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Ce inseamna pentru ferma</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <Card title="Lunca Aluviala">
          Solul aluvial din lunca este ideal pentru topinambur si lucerna — culturi furajere principale. Fertilitatea naturala elimina nevoia de amendamente costisitoare.
        </Card>
        <Card title="Precipitatii Suficiente">
          Precipitatiile de 734 mm/an acopera necesarul fara irigatie suplimentara pentru majoritatea culturilor planificate. Distributia favorabila in sezonul de crestere este un avantaj major.
        </Card>
        <Card title="Versanti pentru Livada">
          Versantii cu luvosoluri sunt potriviti pentru livada traditionala si padure alimentara. Luvosolurile argiloase sustin bine pomii fructiferi si arbustii.
        </Card>
      </div>
    </div>
  </section>

  <!-- 8. Surse -->
  <section class="py-8">
    <div class="max-w-4xl mx-auto px-4">
      <h3 class="font-heading font-semibold text-lg text-verde-padure mb-3">Surse si referinte</h3>
      <ul class="text-sm text-lemn-stejar/60 space-y-1 list-disc list-inside">
        <li>Harta geologica a Romaniei 1:200.000</li>
        <li>Institutul National de Geologie</li>
        <li>OSPA Arges — Oficiul de Studii Pedologice si Agrochimice</li>
        <li>Date meteorologice ANM 2000-2025</li>
      </ul>
    </div>
  </section>

</PageLayout>
