---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import SectionSeparator from '../components/SectionSeparator.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const produse = await getCollection('produse');
---

<PageLayout title="Camara RAIDAVA — Produse de la Ferma" description="Produse naturale din ferma regenerativa: branza de capra, oua de tara, conserve traditionale.">
  <Hero title="Camara RAIDAVA" subtitle="Produse naturale, din grija pentru pamant si animale" />

  <SectionSeparator />

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Produse</h2>
      {produse.length === 0 && (
        <p class="text-center text-lemn-stejar/60">Produsele vor fi disponibile in curand.</p>
      )}
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {produse.map((produs) => (
          <ProductCard
            title={produs.data.title}
            category={produs.data.category}
            season={produs.data.season}
            available={produs.data.available}
          >
            <p class="text-sm text-lemn-stejar">Disponibilitate estimata: 2027</p>
          </ProductCard>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-teracota-light/30">
    <div class="max-w-2xl mx-auto text-center px-4">
      <h3 class="font-heading text-2xl font-bold text-verde-padure mb-4">Precomanda si Distributie</h3>
      <p class="text-lemn-nuc mb-4">
        Primele produse vor fi disponibile incepand cu sezonul 2027. Distributie locala in zona Arges si livrare in Pitesti/Curtea de Arges.
      </p>
      <p class="text-lemn-nuc mb-6">
        Pentru precomanda sau informatii, contactati-ne la contact@vinacasa.eu
      </p>
      <a href="/contact" class="bg-teracota text-white px-6 py-2 rounded-lg inline-block mt-4 hover:bg-teracota/90 transition-colors">
        Contacteaza-ne &rarr;
      </a>
    </div>
  </section>
</PageLayout>
