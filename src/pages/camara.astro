---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import SectionSeparator from '../components/SectionSeparator.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const produse = await getCollection('produse');
---

<PageLayout title="Cămara RAIDAVA — Produse de la Fermă" description="Produse naturale din fermă regenerativă: brânză de capră, ouă de țară, conserve tradiționale.">
  <Hero title="Cămara RAIDAVA" subtitle="Produse naturale, din grijă pentru pământ și animale" />

  <!-- Imagine produse -->
  <div class="relative h-64 md:h-72 overflow-hidden -mt-1">
    <img
      src="/images/branza.jpg"
      alt="Brânză artizanală de capră"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-alb-var/60 to-transparent"></div>
  </div>

  <SectionSeparator />

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Produse</h2>
      {produse.length === 0 && (
        <p class="text-center text-lemn-stejar/60">Produsele vor fi disponibile în curând.</p>
      )}
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {produse.map((produs) => (
          <ProductCard
            title={produs.data.title}
            category={produs.data.category}
            season={produs.data.season}
            available={produs.data.available}
          >
            <p class="text-sm text-lemn-stejar">Disponibilitate estimată: 2027</p>
          </ProductCard>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-teracota-light/30">
    <div class="max-w-2xl mx-auto text-center px-4">
      <h3 class="font-heading text-2xl font-bold text-verde-padure mb-4">Precomandă și Distribuție</h3>
      <p class="text-lemn-nuc mb-4">
        Primele produse vor fi disponibile începând cu sezonul 2027. Distribuție locală în zona Argeș și livrare în Pitești/Curtea de Argeș.
      </p>
      <p class="text-lemn-nuc mb-6">
        Pentru precomandă sau informații, contactați-ne la contact@vinacasa.eu
      </p>
      <a href="/contact" class="bg-teracota text-white px-6 py-2 rounded-lg inline-block mt-4 hover:bg-teracota/90 transition-colors">
        Contactează-ne &rarr;
      </a>
    </div>
  </section>
</PageLayout>
