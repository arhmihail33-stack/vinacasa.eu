---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import BlogCard from '../../components/BlogCard.astro';
import SectionSeparator from '../../components/SectionSeparator.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<PageLayout title="Blog RAIDAVA — Jurnalul Fermei" description="Articole despre agricultură regenerativă, viața la fermă și proiectul RAIDAVA.">
  <Hero title="Jurnalul Fermei" subtitle="Gânduri, decizii și descoperiri de pe câmp" image="/images/pasune.jpg" />

  <SectionSeparator />

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      {posts.length === 0 && (
        <p class="text-center text-lemn-stejar/60">Niciun articol încă. Revino curând!</p>
      )}
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            author={post.data.author}
            image={post.data.image}
          />
        ))}
      </div>
    </div>
  </section>
</PageLayout>
