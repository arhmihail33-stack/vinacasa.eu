---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import StatusCard from '../components/StatusCard.astro';
import SectionSeparator from '../components/SectionSeparator.astro';
---

<PageLayout title="Razvanis — Asistentul AI al Fermei RAIDAVA" description="Agent AI personal care cerceteaza, planifica si invata pentru micro-ferma regenerativa din Vulturesti.">

  <!-- 1. Hero -->
  <Hero
    gradient={true}
    title="Razvanis"
    subtitle="Asistentul AI al Fermei RAIDAVA"
    tagline="Un agent AI care cerceteaza, planifica si invata alaturi de noi"
  />

  <!-- 2. Badge -->
  <div class="py-3 bg-verde-padure/10 text-center">
    <span class="inline-flex items-center gap-2 bg-verde-pasune/20 text-verde-padure px-4 py-2 rounded-full text-sm font-medium">
      <span class="w-2 h-2 bg-verde-pasune rounded-full animate-pulse"></span>
      ONLINE din 2 Aprilie 2026
    </span>
  </div>

  <!-- 3. Separator -->
  <SectionSeparator />

  <!-- 4. StatusCard + Prezentare -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Left: StatusCard -->
        <StatusCard />

        <!-- Right: Prezentare -->
        <div class="space-y-4 text-lemn-stejar leading-relaxed">
          <p>
            <span class="font-semibold text-verde-padure">Razvanis</span> este agentul AI personal construit de la zero pentru proiectul RAIDAVA. Nu este un simplu chatbot — este un cercetator autonom care invata, analizeaza si asista in toate aspectele fermei regenerative din Vulturesti.
          </p>
          <p>
            Interfata principala este prin <span class="font-semibold text-verde-padure">Telegram bot @RazvanisBot</span> — acces instant din camp, din gradina sau de acasa.
          </p>
          <p>
            Ruleaza pe <span class="font-semibold text-verde-padure">5 containere Docker</span> independente, cu infrastructura complet reproductibila.
          </p>
          <p>
            Trimite un <span class="font-semibold text-verde-padure">briefing zilnic la 5:00 AM</span> cu meteo, sarcini prioritare, descoperiri noi si recomandari pentru ziua respectiva.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Separator -->
  <SectionSeparator variant="verde" />

  <!-- 6. Tech Stack -->
  <section class="py-16 bg-teracota-light/30">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Arhitectura Tehnica</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <Card icon="&#x1F433;" title="5 Containere Docker">
          <ul class="space-y-1">
            <li><span class="font-semibold">Redis</span> — cache rapid</li>
            <li><span class="font-semibold">Qdrant</span> — memorie semantica</li>
            <li><span class="font-semibold">PostgreSQL</span> — fapte structurate</li>
            <li><span class="font-semibold">SearXNG</span> — cautare web</li>
            <li><span class="font-semibold">Agent API</span> — nucleul</li>
          </ul>
        </Card>

        <Card icon="&#x1F4F1;" title="Telegram Bot">
          <p class="mb-2"><span class="font-semibold">@RazvanisBot</span> — acces instant din camp.</p>
          <p>Comenzi: <code class="text-xs bg-verde-padure/10 px-1 rounded">/status</code>, <code class="text-xs bg-verde-padure/10 px-1 rounded">/search</code>, <code class="text-xs bg-verde-padure/10 px-1 rounded">/recall</code>, <code class="text-xs bg-verde-padure/10 px-1 rounded">/facts</code>, <code class="text-xs bg-verde-padure/10 px-1 rounded">/budget</code>, <code class="text-xs bg-verde-padure/10 px-1 rounded">/emergency</code></p>
        </Card>

        <Card icon="&#x1F9E0;" title="Memorie 5 Niveluri">
          <ul class="space-y-1">
            <li><span class="font-semibold">T1</span> Redis — hot cache 24h</li>
            <li><span class="font-semibold">T2</span> Qdrant — embedding semantic</li>
            <li><span class="font-semibold">T3</span> PostgreSQL — fapte, decizii, entitati</li>
            <li><span class="font-semibold">T4</span> DuckDB — analytics</li>
            <li><span class="font-semibold">T5</span> Arhiva fisiere</li>
          </ul>
        </Card>

        <Card icon="&#x1F916;" title="Modele AI Cloud">
          <p class="mb-2 font-semibold">Ollama:</p>
          <ul class="space-y-1 mb-3">
            <li><span class="font-semibold">qwen3.5:397b</span> — analiza complexa</li>
            <li><span class="font-semibold">qwen3-next:80b</span> — conversatie</li>
            <li><span class="font-semibold">qwen3-vl:235b</span> — viziune</li>
          </ul>
          <p><span class="font-semibold">STT/TTS:</span> Piper voce romaneasca mihai-medium</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- 7. Separator -->
  <SectionSeparator />

  <!-- 8. Ce cerceteaza Razvanis -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Domeniile de Cercetare</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-crem rounded-lg p-6 border-l-4 border-verde-pasune">
          <div class="text-2xl mb-2">&#x1F331;</div>
          <h3 class="font-heading font-semibold text-lg text-verde-padure mb-2">Agricultura Regenerativa</h3>
          <p class="text-sm text-lemn-stejar">Tehnici sol, compostare, rotatie culturi, biochar, no-till, biodiversitate sol.</p>
        </div>
        <div class="bg-crem rounded-lg p-6 border-l-4 border-verde-padure">
          <div class="text-2xl mb-2">&#x1F410;</div>
          <h3 class="font-heading font-semibold text-lg text-verde-padure mb-2">Crestere Animale Autonoma</h3>
          <p class="text-sm text-lemn-stejar">Pasunit rotativ, rase rustice, silvopastoralism, nutritie din resurse proprii.</p>
        </div>
        <div class="bg-crem rounded-lg p-6 border-l-4 border-teracota">
          <div class="text-2xl mb-2">&#x1F33F;</div>
          <h3 class="font-heading font-semibold text-lg text-verde-padure mb-2">Plante Perene</h3>
          <p class="text-sm text-lemn-stejar">Food forests, arbusti fructiferi, plante furajere perene, livezi multistrat.</p>
        </div>
        <div class="bg-crem rounded-lg p-6 border-l-4 border-lemn-nuc">
          <div class="text-2xl mb-2">&#x267B;&#xFE0F;</div>
          <h3 class="font-heading font-semibold text-lg text-verde-padure mb-2">Sisteme Auto-sustenabile</h3>
          <p class="text-sm text-lemn-stejar">Cicluri inchise, colectare apa, conservare fara electricitate, biogas.</p>
        </div>
        <div class="bg-crem rounded-lg p-6 border-l-4 border-verde-pasune">
          <div class="text-2xl mb-2">&#x1FAD5;</div>
          <h3 class="font-heading font-semibold text-lg text-verde-padure mb-2">Fermentare si Conservare</h3>
          <p class="text-sm text-lemn-stejar">Branza, carnati, muraturi, otet, paine, siloz, deshidratare.</p>
        </div>
        <div class="bg-crem rounded-lg p-6 border-l-4 border-teracota">
          <div class="text-2xl mb-2">&#x1F4CB;</div>
          <h3 class="font-heading font-semibold text-lg text-verde-padure mb-2">Legislatie Romania</h3>
          <p class="text-sm text-lemn-stejar">PFA, subventii APIA/AFIR, norme ANSVSA, certificare bio, vanzare directa.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. Separator -->
  <SectionSeparator variant="verde" />

  <!-- 10. Jurnalul Cercetarii -->
  <section class="py-16 bg-teracota-light/30">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Jurnalul Cercetarii</h2>
      <div class="bg-crem rounded-lg p-10 text-center border border-teracota-light/50">
        <div class="w-12 h-12 bg-verde-padure/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-verde-padure/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <p class="text-lemn-stejar/60 font-heading font-medium">
          Jurnalul de cercetare va fi populat automat pe masura ce Razvanis descopera informatii noi.
        </p>
      </div>
    </div>
  </section>

  <!-- 11. Arhitectura -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">Schema Tehnica</h2>
      <div class="bg-crem rounded-lg p-6 border border-teracota-light/50 overflow-x-auto">
        <svg viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl mx-auto">
          <!-- Telegram -->
          <rect x="20" y="160" width="140" height="60" rx="8" fill="#2D5016" opacity="0.15" stroke="#2D5016" stroke-width="2"/>
          <text x="90" y="185" text-anchor="middle" fill="#2D5016" font-size="13" font-weight="bold">Telegram</text>
          <text x="90" y="205" text-anchor="middle" fill="#2D5016" font-size="10">@RazvanisBot</text>

          <!-- Arrow: Telegram -> Agent API -->
          <line x1="160" y1="190" x2="260" y2="190" stroke="#C84B31" stroke-width="2" marker-end="url(#arrowhead)"/>

          <!-- Agent API -->
          <rect x="260" y="140" width="160" height="100" rx="8" fill="#2D5016" opacity="0.2" stroke="#2D5016" stroke-width="2"/>
          <text x="340" y="180" text-anchor="middle" fill="#2D5016" font-size="14" font-weight="bold">Agent API</text>
          <text x="340" y="200" text-anchor="middle" fill="#2D5016" font-size="10">Nucleul sistemului</text>
          <text x="340" y="218" text-anchor="middle" fill="#2D5016" font-size="10">Python + FastAPI</text>

          <!-- Arrow: Agent API -> Memory -->
          <line x1="420" y1="190" x2="530" y2="140" stroke="#C84B31" stroke-width="2" marker-end="url(#arrowhead)"/>
          <line x1="420" y1="190" x2="530" y2="190" stroke="#C84B31" stroke-width="2" marker-end="url(#arrowhead)"/>
          <line x1="420" y1="190" x2="530" y2="240" stroke="#C84B31" stroke-width="2" marker-end="url(#arrowhead)"/>

          <!-- Memory Tiers (right, stacked) -->
          <rect x="530" y="50" width="240" height="40" rx="6" fill="#2D5016" opacity="0.1" stroke="#2D5016" stroke-width="1.5"/>
          <text x="650" y="75" text-anchor="middle" fill="#2D5016" font-size="11">T1 Redis — hot cache 24h</text>

          <rect x="530" y="100" width="240" height="40" rx="6" fill="#2D5016" opacity="0.1" stroke="#2D5016" stroke-width="1.5"/>
          <text x="650" y="125" text-anchor="middle" fill="#2D5016" font-size="11">T2 Qdrant — embedding semantic</text>

          <rect x="530" y="150" width="240" height="40" rx="6" fill="#2D5016" opacity="0.1" stroke="#2D5016" stroke-width="1.5"/>
          <text x="650" y="175" text-anchor="middle" fill="#2D5016" font-size="11">T3 PostgreSQL — fapte</text>

          <rect x="530" y="200" width="240" height="40" rx="6" fill="#2D5016" opacity="0.1" stroke="#2D5016" stroke-width="1.5"/>
          <text x="650" y="225" text-anchor="middle" fill="#2D5016" font-size="11">T4 DuckDB — analytics</text>

          <rect x="530" y="250" width="240" height="40" rx="6" fill="#2D5016" opacity="0.1" stroke="#2D5016" stroke-width="1.5"/>
          <text x="650" y="275" text-anchor="middle" fill="#2D5016" font-size="11">T5 Arhiva fisiere</text>

          <!-- Arrow: Agent API -> Ollama -->
          <line x1="340" y1="240" x2="240" y2="320" stroke="#C84B31" stroke-width="2" marker-end="url(#arrowhead)"/>

          <!-- Ollama -->
          <rect x="140" y="300" width="200" height="60" rx="8" fill="#2D5016" opacity="0.15" stroke="#2D5016" stroke-width="2"/>
          <text x="240" y="325" text-anchor="middle" fill="#2D5016" font-size="13" font-weight="bold">Ollama Cloud</text>
          <text x="240" y="345" text-anchor="middle" fill="#2D5016" font-size="10">qwen3.5 / qwen3-next / qwen3-vl</text>

          <!-- Arrow: Agent API -> SearXNG -->
          <line x1="340" y1="240" x2="460" y2="320" stroke="#C84B31" stroke-width="2" marker-end="url(#arrowhead)"/>

          <!-- SearXNG -->
          <rect x="380" y="300" width="160" height="60" rx="8" fill="#2D5016" opacity="0.15" stroke="#2D5016" stroke-width="2"/>
          <text x="460" y="325" text-anchor="middle" fill="#2D5016" font-size="13" font-weight="bold">SearXNG</text>
          <text x="460" y="345" text-anchor="middle" fill="#2D5016" font-size="10">Cautare web privata</text>

          <!-- Arrowhead marker -->
          <defs>
            <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
              <polygon points="0 0, 10 3.5, 0 7" fill="#C84B31"/>
            </marker>
          </defs>
        </svg>
      </div>
      <p class="text-center mt-6 text-sm">
        <a href="https://github.com/arhmihail33-stack" target="_blank" rel="noopener" class="text-teracota hover:text-teracota/80 font-medium transition-colors">
          Profil GitHub: arhmihail33-stack
        </a>
      </p>
    </div>
  </section>

</PageLayout>
