---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import SectionSeparator from '../components/SectionSeparator.astro';
---

<PageLayout title="Contact — RAIDAVA" description="Contactează-ne pentru informații despre ferma RAIDAVA din Vulturești, Argeș.">
  <Hero
    title="Contact"
    subtitle="Suntem aici pentru întrebări și vizite"
    image="https://images.unsplash.com/photo-1501004318855-b174af8ba024?w=1600&h=900&fit=crop&q=80"
    overlay="green"
  />

  <SectionSeparator />

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 grid md:grid-cols-2 gap-8">
      <!-- Formular contact -->
      <div>
        <h2 class="font-heading text-2xl font-bold text-verde-padure mb-6">Trimite un mesaj</h2>
        <form name="contact" method="POST" data-netlify="true" class="space-y-4">
          <input type="hidden" name="form-name" value="contact" />
          <div>
            <label for="name" class="block text-sm font-medium text-lemn-nuc mb-1">Nume</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-2 border border-teracota-light rounded-lg bg-crem text-lemn-nuc focus:outline-none focus:ring-2 focus:ring-verde-pasune" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-lemn-nuc mb-1">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-teracota-light rounded-lg bg-crem text-lemn-nuc focus:outline-none focus:ring-2 focus:ring-verde-pasune" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-lemn-nuc mb-1">Mesaj</label>
            <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2 border border-teracota-light rounded-lg bg-crem text-lemn-nuc focus:outline-none focus:ring-2 focus:ring-verde-pasune"></textarea>
          </div>
          <button type="submit" class="bg-teracota hover:bg-teracota/90 text-white px-8 py-3 rounded-lg font-medium transition-colors">Trimite</button>
        </form>
      </div>

      <!-- Info + Harta -->
      <div>
        <h2 class="font-heading text-2xl font-bold text-verde-padure mb-6">Locație</h2>
        <div class="space-y-3 text-lemn-nuc">
          <p>Comuna Vulturești, Județul Argeș, România</p>
          <p>Email: <a href="mailto:contact@vinacasa.eu" class="text-verde-padure hover:text-teracota transition-colors">contact@vinacasa.eu</a></p>
        </div>
        <iframe
          src="https://www.openstreetmap.org/export/embed.html?bbox=24.82%2C44.83%2C24.94%2C44.93&layer=mapnik&marker=44.88%2C24.88"
          class="w-full h-64 rounded-lg border border-teracota-light mt-4"
          loading="lazy"
          title="Harta RAIDAVA Vulturești"
        ></iframe>
        <a href="https://www.openstreetmap.org/?mlat=44.88&mlon=24.88#map=13/44.88/24.88" target="_blank" class="text-xs text-verde-padure hover:text-teracota">Vezi harta completă &rarr;</a>
      </div>
    </div>
  </section>

  <section class="py-8 bg-teracota-light/30">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="italic text-lemn-stejar">Ferma este în construcție. Vizitele vor fi posibile începând din 2027.</p>
    </div>
  </section>
</PageLayout>
