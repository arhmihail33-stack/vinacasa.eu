---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import Timeline from '../components/Timeline.astro';
import SectionSeparator from '../components/SectionSeparator.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<PageLayout
  title="RAIDAVA — Agricultura Sustenabila in Vulturesti, Arges"
  description="RAIDAVA este prima ferma Hub-and-Spoke din Romania. Agricultura regenerativa, zero input extern, sistem circular complet in Vulturesti, judetul Arges."
>
  <!-- 1. Hero -->
  <Hero
    gradient={true}
    title="RAIDAVA"
    subtitle="Agricultura Sustenabila. Traditie Respectata."
    tagline="Ferma care se hraneste singura — Vulturesti, Arges"
    cta={{ text: "Descopera Povestea →", href: "/despre" }}
  />

  <!-- 2. Etimologie -->
  <section class="py-6 bg-verde-padure/5 text-center">
    <p class="text-sm italic text-lemn-stejar max-w-2xl mx-auto px-4">
      <span class="font-heading font-semibold text-verde-padure">Rai</span> (paradis romanesc) +
      <span class="font-heading font-semibold text-verde-padure">Dava</span> (asezare dacica fortificata) =
      <span class="font-heading font-bold text-teracota">RAIDAVA</span>
    </p>
  </section>

  <!-- 3. Separator -->
  <SectionSeparator variant="teracota" />

  <!-- 4. Despre Ferma -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">
        Prima Ferma Hub-and-Spoke din Romania
      </h2>

      <div class="space-y-4 text-lemn-stejar leading-relaxed">
        <p>
          RAIDAVA este un proiect de agricultura regenerativa situat pe Piemontul Getic, in comuna
          Vulturesti, judetul Arges. Pe un hectar de teren, construim un sistem circular complet
          in care animalele hranesc solul, solul hraneste plantele, iar plantele hranesc animalele.
        </p>
        <p>
          Principiul nostru fundamental: <strong class="text-verde-padure">zero input extern</strong>.
          Fara furaje cumparate, fara chimicale, fara dependenta de piata. Ferma produce tot ce consuma,
          iar ceea ce iese din ciclu este un surplus curat — oua, lapte, branza, carne crescuta natural.
        </p>
        <p>
          Modelul Hub-and-Spoke imparte terenul in 4 parcele care se rotesc continuu: animalele pasc,
          fertilizeaza si trec mai departe. In urma lor, solul se reface si culturile cresc fara interventia
          chimica. Este un dans calculat intre natura si planificare.
        </p>
        <p>
          Viziunea noastra nu este doar sustenabilitatea — este regenerarea. Cu fiecare sezon, solul devine
          mai fertil, biodiversitatea creste, iar ferma se apropie de autonomie completa. RAIDAVA nu este
          doar o ferma; este o demonstratie ca agricultura romaneasca poate fi altfel.
        </p>
      </div>
    </div>
  </section>

  <!-- 5. Separator -->
  <SectionSeparator variant="verde" />

  <!-- 6. Ce Oferim -->
  <section class="py-16 bg-teracota-light/30">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-10 text-center">
        Ce Oferim
      </h2>

      <div class="grid md:grid-cols-3 gap-6">
        <Card icon="🐐" title="Animale Fericite">
          <p>
            Mangalita, capre, pasari — toate crescute pe pasuni curate, in sistem extensiv,
            cu respectul pe care il merita. Fara custi, fara stres, fara compromisuri.
          </p>
          <a href="/ferma" class="inline-block mt-3 text-teracota font-medium text-sm hover:underline">
            Descopera animalele →
          </a>
        </Card>

        <Card icon="🌱" title="Pamant Regenerat">
          <p>
            1 hectar organizat in sistem Hub-and-Spoke cu 4 parcele in rotatie continua.
            Solul se reface natural, fara chimicale, an de an mai fertil.
          </p>
          <a href="/ferma" class="inline-block mt-3 text-teracota font-medium text-sm hover:underline">
            Vezi structura fermei →
          </a>
        </Card>

        <Card icon="🤖" title="Tehnologie AI">
          <p>
            Razvanis este agentul AI al fermei — monitorizeaza, invata si ne ajuta sa luam
            decizii mai bune cu fiecare ciclu.
          </p>
          <a href="/razvanis" class="inline-block mt-3 text-teracota font-medium text-sm hover:underline">
            Cunoaste-l pe Razvanis →
          </a>
        </Card>
      </div>
    </div>
  </section>

  <!-- 7. Separator -->
  <SectionSeparator variant="teracota" />

  <!-- 8. Calendarul Fermei -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-8 text-center">
        Calendarul Fermei
      </h2>

      <Timeline items={[
        { period: "Primavara 2026", description: "Pregatire teren, imprejmuire, adaposturi. Primele animale: gaini + rate.", highlight: true },
        { period: "Vara 2026", description: "Semanare parcele, achizitie porci Mangalita, instalare sistem rotatie." },
        { period: "Toamna 2026", description: "Prima recolta topinambur, achizitie capre, constructie adapost." },
        { period: "Iarna 2026-2027", description: "Evaluare primul ciclu, planificare anul 2, fermentare si conservare." },
      ]} />
    </div>
  </section>

  <!-- 9. Separator -->
  <SectionSeparator variant="verde" />

  <!-- 10. Din Jurnalul Fermei -->
  <section class="py-16 bg-teracota-light/30">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-verde-padure mb-10 text-center">
        Din Jurnalul Fermei
      </h2>

      {posts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              author={post.data.author}
            />
          ))}
        </div>
      ) : (
        <p class="text-center text-lemn-stejar italic">
          Jurnalul fermei se deschide in curand...
        </p>
      )}

      <div class="text-center">
        <a
          href="/blog"
          class="inline-block text-teracota hover:text-teracota/80 font-medium transition-colors"
        >
          Vezi toate articolele →
        </a>
      </div>
    </div>
  </section>
</PageLayout>
