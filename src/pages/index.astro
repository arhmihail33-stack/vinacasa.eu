---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import Timeline from '../components/Timeline.astro';
import SectionSeparator from '../components/SectionSeparator.astro';
import BlogCard from '../components/BlogCard.astro';
import WeatherWidget from '../components/WeatherWidget.astro';
import AnimatedCounter from '../components/AnimatedCounter.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<PageLayout
  title="RAIDAVA — Agricultură Sustenabilă în Vulturești, Argeș"
  description="RAIDAVA este prima fermă Hub-and-Spoke din România. Agricultură regenerativă, zero input extern, sistem circular complet în Vulturești, județul Argeș."
>
  <!-- 1. Hero with background image -->
  <Hero
    image="https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=1600&h=900&fit=crop&q=80"
    overlay="green"
    tall={true}
    title="RAIDAVA"
    subtitle="Agricultură Sustenabilă. Tradiție Respectată."
    tagline="Fermă care se hrănește singură — Vulturești, Argeș"
    cta={{ text: "Descoperă Povestea →", href: "/despre" }}
  />

  <!-- 2. Etimologie -->
  <section class="py-8 bg-verde-padure/5 text-center">
    <p class="text-sm italic text-lemn-stejar max-w-2xl mx-auto px-4">
      <span class="font-heading font-semibold text-verde-padure">Rai</span> (paradis românesc) +
      <span class="font-heading font-semibold text-verde-padure">Dava</span> (așezare dacică fortificată) =
      <span class="font-heading font-bold text-teracota">RAIDAVA</span>
    </p>
  </section>

  <!-- Meteo live -->
  <section class="py-6">
    <div class="max-w-sm mx-auto px-4">
      <WeatherWidget />
    </div>
  </section>

  <!-- 3. Separator -->
  <SectionSeparator variant="teracota" />

  <!-- 4. Despre Ferma — image + text split -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-verde-padure mb-12 text-center">
        Prima Fermă Hub-and-Spoke din România
      </h2>

      <div class="grid md:grid-cols-2 gap-10 items-center mb-12">
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img
            src="https://images.unsplash.com/photo-1500595046743-cd271d694d30?w=800&h=600&fit=crop&q=80"
            alt="Câmpuri verzi pe dealuri"
            class="w-full h-80 object-cover"
            loading="lazy"
          />
        </div>
        <div class="space-y-4 text-lemn-stejar leading-relaxed">
          <p>
            RAIDAVA este un proiect de agricultură regenerativă situat pe Piemontul Getic, în comuna
            Vulturești, județul Argeș. Pe un hectar de teren, construim un sistem circular complet
            în care animalele hrănesc solul, solul hrănește plantele, iar plantele hrănesc animalele.
          </p>
          <p>
            Principiul nostru fundamental: <strong class="text-verde-padure">zero input extern</strong>.
            Fără furaje cumpărate, fără chimicale, fără dependență de piață.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div class="space-y-4 text-lemn-stejar leading-relaxed md:order-1">
          <p>
            Modelul Hub-and-Spoke împarte terenul în 4 parcele care se rotesc continuu: animalele pasc,
            fertilizează și trec mai departe. În urma lor, solul se reface și culturile cresc fără intervenția chimică.
          </p>
          <p>
            Viziunea noastră nu este doar sustenabilitatea — este regenerarea. Cu fiecare sezon, solul devine
            mai fertil, biodiversitatea crește, iar ferma se apropie de autonomie completă.
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg md:order-2">
          <img
            src="https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=800&h=600&fit=crop&q=80"
            alt="Pășune cu flori sălbatice"
            class="w-full h-80 object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Separator -->
  <SectionSeparator variant="verde" />

  <!-- 6. Ce Oferim — with images -->
  <section class="py-20 bg-teracota-light/30">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-verde-padure mb-12 text-center">
        Ce Oferim
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <Card image="https://images.unsplash.com/photo-1524024973431-2ad916746264?w=600&h=400&fit=crop&q=80" title="Animale Fericite">
          <p>
            Mangalița, capre, păsări — toate crescute pe pășuni curate, în sistem extensiv,
            cu respectul pe care îl merită.
          </p>
          <a href="/ferma" class="inline-block mt-3 text-teracota font-medium text-sm hover:underline">
            Descoperă animalele →
          </a>
        </Card>

        <Card image="https://images.unsplash.com/photo-1574943320219-553eb213f72d?w=600&h=400&fit=crop&q=80" title="Pământ Regenerat">
          <p>
            1 hectar organizat în sistem Hub-and-Spoke cu 4 parcele în rotație continuă.
            Solul se reface natural, an de an mai fertil.
          </p>
          <a href="/ferma" class="inline-block mt-3 text-teracota font-medium text-sm hover:underline">
            Vezi structura fermei →
          </a>
        </Card>

        <Card image="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=600&h=400&fit=crop&q=80" title="Tehnologie AI">
          <p>
            Razvanis este agentul AI al fermei — monitorizează, învață și ne ajută să luăm
            decizii mai bune cu fiecare ciclu.
          </p>
          <a href="/razvanis" class="inline-block mt-3 text-teracota font-medium text-sm hover:underline">
            Cunoaște-l pe Razvanis →
          </a>
        </Card>
      </div>
    </div>
  </section>

  <!-- 7. Separator -->
  <SectionSeparator variant="teracota" />

  <!-- Full-width image break -->
  <section class="relative h-64 md:h-80 overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1464226184884-fa280b87c399?w=1600&h=600&fit=crop&q=80"
      alt="Peisaj rural"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-verde-padure/60 to-transparent flex items-center">
      <div class="max-w-4xl mx-auto px-8">
        <blockquote class="text-white text-xl md:text-2xl font-heading italic drop-shadow-lg max-w-lg">
          "Ferma produce tot ce consumă, iar ceea ce iese din ciclu este un surplus curat."
        </blockquote>
      </div>
    </div>
  </section>

  <!-- 8. Calendarul Fermei -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-verde-padure mb-10 text-center">
        Calendarul Fermei
      </h2>

      <Timeline items={[
        { period: "Iunie 2026", description: "Sosire în România. Evaluare teren, primele contacte locale, înregistrare PFA.", highlight: true },
        { period: "Iulie-August 2026", description: "Împrejmuire teren, construcție adăposturi, achiziție echipament RURIS." },
        { period: "Septembrie-Octombrie 2026", description: "Primele animale: găini (20-30) + rațe (20) + gâște (5). Semănare parcele de toamnă." },
        { period: "Iarna 2026-2027", description: "Achiziție porci Mangalița (3-5). Construcție adăpost capre. Planificare Anul 2." },
        { period: "Primăvara 2027", description: "Achiziție capre (3). Semănare parcele primăvară. Primul ciclu Hub-and-Spoke complet." },
      ]} />
    </div>
  </section>

  <!-- 9. Separator -->
  <SectionSeparator variant="verde" />

  <!-- Cifre cheie -->
  <AnimatedCounter items={[
    { value: 1, suffix: ' ha', label: 'Teren' },
    { value: 4, label: 'Parcele' },
    { value: 5, label: 'Specii animale' },
    { value: 734, suffix: ' mm', label: 'Precipitații/an' },
    { value: 65, suffix: '%', label: 'Păduri' },
  ]} />

  <!-- 10. Separator -->
  <SectionSeparator variant="teracota" />

  <!-- 11. Din Jurnalul Fermei -->
  <section class="py-20 bg-teracota-light/30">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-verde-padure mb-12 text-center">
        Din Jurnalul Fermei
      </h2>

      {posts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              author={post.data.author}
            />
          ))}
        </div>
      ) : (
        <p class="text-center text-lemn-stejar italic">
          Jurnalul fermei se deschide în curând...
        </p>
      )}

      <div class="text-center">
        <a
          href="/blog"
          class="inline-block text-teracota hover:text-teracota/80 font-medium transition-colors"
        >
          Vezi toate articolele →
        </a>
      </div>
    </div>
  </section>
</PageLayout>
