---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RAIDAVA — Ferma care se hraneste singura">
  <!-- Hero -->
  <section class="bg-green-primary text-white py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-heading text-4xl md:text-6xl font-extrabold mb-4 tracking-tight">RAIDAVA</h1>
      <p class="text-xl md:text-2xl font-heading font-medium text-cream-dark mb-2">Rai + Dava = Ferma care se hraneste singura</p>
      <p class="text-lg text-cream-dark/80 mb-6">Prima ferma Hub-and-Spoke + Mulberry-Dike din Romania</p>
      <p class="text-sm text-cream-dark/60">Vulturesti, comuna Vulturesti, judetul Arges, Romania</p>
    </div>
  </section>

  <!-- Viziune -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-green-primary mb-8 text-center">Viziune</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="text-3xl mb-3">0</div>
          <h3 class="font-heading font-semibold text-lg mb-2">Zero Input Extern</h3>
          <p class="text-sm text-green-primary/70">Fara furaje cumparate, fara chimicale, fara dependenta de piata. Ferma produce tot ce consuma.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="text-3xl mb-3">&#x267B;</div>
          <h3 class="font-heading font-semibold text-lg mb-2">Sistem Circular</h3>
          <p class="text-sm text-green-primary/70">Animalele hranesc solul, solul hraneste plantele, plantele hranesc animalele. Ciclul se inchide perfect.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="text-3xl mb-3">&#x1F331;</div>
          <h3 class="font-heading font-semibold text-lg mb-2">Agricultura Regenerativa</h3>
          <p class="text-sm text-green-primary/70">Nu doar sustenabil — regenerativ. Solul devine mai fertil in fiecare an, biodiversitatea creste.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Planul Anul 1 -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-green-primary mb-8 text-center">Planul Anul 1</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Animale -->
        <div>
          <h3 class="font-heading text-xl font-semibold mb-4 text-brown-earth">Animale</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-xl shrink-0">&#x1F416;</span>
              <div>
                <p class="font-medium">3-5 porci Mangalita</p>
                <p class="text-sm text-green-primary/60">Rasa rustica, rezistenta, ideal pentru pasune si padure</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-xl shrink-0">&#x1F410;</span>
              <div>
                <p class="font-medium">3 capre</p>
                <p class="text-sm text-green-primary/60">Lapte, branza, intretinere vegetatie</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-xl shrink-0">&#x1F414;</span>
              <div>
                <p class="font-medium">20-30 gaini</p>
                <p class="text-sm text-green-primary/60">Oua, control daunatori, fertilizare sol</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-xl shrink-0">&#x1F986;</span>
              <div>
                <p class="font-medium">20 rate</p>
                <p class="text-sm text-green-primary/60">Control melci/insecte, oua, carne</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-xl shrink-0">&#x1FABF;</span>
              <div>
                <p class="font-medium">5 gaste</p>
                <p class="text-sm text-green-primary/70">Paza, iarba, pene, carne</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Teren -->
        <div>
          <h3 class="font-heading text-xl font-semibold mb-4 text-brown-earth">Teren: 1 ha Hub-and-Spoke</h3>
          <p class="text-sm text-green-primary/60 mb-4">4 parcele de ~2.500 m<sup>2</sup> fiecare, rotatie continua</p>
          <div class="space-y-3">
            <div class="bg-cream rounded-lg p-4 border-l-4 border-green-secondary">
              <p class="font-medium text-sm">Parcela Nord</p>
              <p class="text-sm text-green-primary/70">Topinambur + trifoi/cicoare + hrean + urzica</p>
            </div>
            <div class="bg-cream rounded-lg p-4 border-l-4 border-green-light">
              <p class="font-medium text-sm">Parcela Est</p>
              <p class="text-sm text-green-primary/70">Lucerna + kale</p>
            </div>
            <div class="bg-cream rounded-lg p-4 border-l-4 border-brown-earth">
              <p class="font-medium text-sm">Parcela Sud</p>
              <p class="text-sm text-green-primary/70">Pasune pura</p>
            </div>
            <div class="bg-cream rounded-lg p-4 border-l-4 border-brown-light">
              <p class="font-medium text-sm">Parcela Vest</p>
              <p class="text-sm text-green-primary/70">Secara + vicia + kale + pasune</p>
            </div>
          </div>
          <div class="mt-4 bg-green-primary/5 border border-green-primary/20 rounded-lg p-3">
            <p class="text-sm font-medium text-green-primary">Regula critica: gainile urmeaza porcii exact in zilele 3-4</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Echipament -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-green-primary mb-8 text-center">Echipament</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <h3 class="font-heading font-semibold text-lg mb-2">RURIS 918 ACC PRO</h3>
          <p class="text-sm text-green-primary/70">Motocultivator profesional pentru lucrarile de baza ale fermei — arat, frezat, transport.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <h3 class="font-heading font-semibold text-lg mb-2">RURIS 600S 4x4</h3>
          <p class="text-sm text-green-primary/70">Minitractor 4x4 pentru transport materiale, remorca, si lucrari mai grele pe teren accidentat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Calendar -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-green-primary mb-8 text-center">Calendarul Fermei</h2>
      <div class="relative">
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-green-secondary/30"></div>
        <div class="space-y-8">
          <div class="relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-8">
            <div class="md:text-right md:pr-8">
              <span class="absolute left-2 md:left-1/2 md:-translate-x-1/2 w-5 h-5 bg-green-secondary rounded-full border-2 border-cream"></span>
              <p class="font-heading font-bold text-brown-earth">Primavara 2026</p>
              <p class="text-sm text-green-primary/70">Pregatire teren, imprejmuire, adaposturi temporare. Primele animale: gaini + rate.</p>
            </div>
            <div class="hidden md:block"></div>
          </div>
          <div class="relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-8">
            <div class="hidden md:block"></div>
            <div class="md:pl-8">
              <span class="absolute left-2 md:left-1/2 md:-translate-x-1/2 w-5 h-5 bg-green-secondary rounded-full border-2 border-cream"></span>
              <p class="font-heading font-bold text-brown-earth">Vara 2026</p>
              <p class="text-sm text-green-primary/70">Semanare parcele, achizitie porci Mangalita, instalare sistem rotatie.</p>
            </div>
          </div>
          <div class="relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-8">
            <div class="md:text-right md:pr-8">
              <span class="absolute left-2 md:left-1/2 md:-translate-x-1/2 w-5 h-5 bg-green-secondary rounded-full border-2 border-cream"></span>
              <p class="font-heading font-bold text-brown-earth">Toamna 2026</p>
              <p class="text-sm text-green-primary/70">Prima recolta topinambur, achizitie capre, constructie adapost iarna.</p>
            </div>
            <div class="hidden md:block"></div>
          </div>
          <div class="relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-8">
            <div class="hidden md:block"></div>
            <div class="md:pl-8">
              <span class="absolute left-2 md:left-1/2 md:-translate-x-1/2 w-5 h-5 bg-green-secondary rounded-full border-2 border-cream"></span>
              <p class="font-heading font-bold text-brown-earth">Iarna 2026-2027</p>
              <p class="text-sm text-green-primary/70">Evaluare primul ciclu, planificare anul 2, fermentare si conservare.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
